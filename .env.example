# FolderRAG Environment Configuration
# Only settings below are actually read from .env by the application.
# Other configuration (embedder, chunker, binary, vector store) comes from config.yaml.

HOST=0.0.0.0
PORT=8000
WATCH_DIR=./watch_folder          # 要监控的目录
DEEPSEEK_API_KEY=sk-xxxx          # DeepSeek API key (仅当 embedder.backend 为 deepseek 时需要)
